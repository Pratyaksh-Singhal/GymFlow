# GymFlow .env.local.example
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control

# ============================================================================
# SUPABASE CONFIGURATION
# Get these from: https://supabase.com/dashboard → Project Settings → API
# ============================================================================

# Public API URL (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public Anon Key (safe to expose - for client-side requests)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Service Role Key (KEEP SECRET - never commit!)
# Only use on server side for admin operations
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# JWT Secret (from Project Settings → Security → JWT Settings)
# Used to sign/verify JWT tokens
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ============================================================================
# DATABASE CONFIGURATION
# Get connection strings from: Project Settings → Database → Connection Pooling
# ============================================================================

# Pooled connection (for Vercel/serverless, recommended)
DATABASE_URL=postgresql://postgres:your-password@your-host.supabase.co:6543/postgres?schema=public&pgbouncer=true

# Direct connection (for local dev with migrations)
DATABASE_URL_UNPOOLED=postgresql://postgres:your-password@your-host.supabase.co:5432/postgres?schema=public

# ============================================================================
# RESEND EMAIL API
# Get key from: https://resend.com/settings/api-keys
# ============================================================================

RESEND_API_KEY=your-resend-api-key-here

# ============================================================================
# TWILIO SMS/WHATSAPP
# Get credentials from: https://console.twilio.com/
# ============================================================================

TWILIO_ACCOUNT_SID=your-twilio-account-sid-here
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================================
# SENTRY ERROR TRACKING
# Get DSN from: https://sentry.io/settings/organization/projects/
# ============================================================================

SENTRY_DSN=https://your-sentry-dsn-here

# ============================================================================
# UPSTASH REDIS (Rate Limiting)
# Get credentials from: https://console.upstash.com/
# ============================================================================

UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Environment mode
NODE_ENV=development

# Application URL (used for redirects, cookies, etc)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your-jwt-secret-for-session-tokens-here
JWT_EXPIRY=3600

# Refresh token expiry (7 days in seconds)
REFRESH_TOKEN_EXPIRY=604800

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable SMS notifications
ENABLE_SMS=true

# Enable WhatsApp notifications
ENABLE_WHATSAPP=true

# Enable email notifications
ENABLE_EMAIL=true

# ============================================================================
# RATE LIMITING
# ============================================================================

# Requests per minute per tenant
RATE_LIMIT_PER_MINUTE=100

# ============================================================================
# LOGGING
# ============================================================================

# Log level: debug, info, warn, error
LOG_LEVEL=debug

# ============================================================================
# NOTES
# ============================================================================

# 1. Never commit .env.local to Git (it's in .gitignore)
# 2. For production, use Vercel Environment Variables dashboard
# 3. Rotate credentials if ever exposed:
#    - Resend API key: https://resend.com/settings/api-keys
#    - Twilio keys: https://console.twilio.com/account/keys-credentials
#    - Supabase service key: https://supabase.com/dashboard → API Settings
# 4. DATABASE_URL_UNPOOLED is for migrations (uses direct connection)
# 5. DATABASE_URL is for application (uses PgBouncer pooling)
# 6. All keys marked "KEEP SECRET" should only be used on server side
