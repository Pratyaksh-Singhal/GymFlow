{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm ci",
  "framework": "nextjs",
  "regions": ["iad1"],
  "git": {
    "deploymentEnabled": {
      "main": true,
      "staging": true
    }
  },
  "crons": [
    {
      "path": "/api/crons/send-notifications",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/crons/process-fee-reminders",
      "schedule": "0 9 * * *"
    }
  ]
}
