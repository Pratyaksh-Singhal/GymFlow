{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm ci",
  "framework": "nextjs",
  "env": [
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "DATABASE_URL",
    "DATABASE_URL_UNPOOLED",
    "SUPABASE_SERVICE_ROLE_KEY",
    "SUPABASE_JWT_SECRET",
    "NEXTAUTH_SECRET",
    "NEXTAUTH_URL",
    "RESEND_API_KEY",
    "TWILIO_ACCOUNT_SID",
    "TWILIO_AUTH_TOKEN",
    "TWILIO_PHONE_NUMBER",
    "SENTRY_DSN",
    "SENTRY_AUTH_TOKEN",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",
    "NODE_ENV",
    "NEXT_PUBLIC_APP_URL",
    "LOG_LEVEL"
  ],
  "regions": ["iad1"],
  "git": {
    "deploymentEnabled": {
      "main": true,
      "staging": true
    }
  },
  "crons": [
    {
      "path": "/api/crons/send-notifications",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/crons/process-fee-reminders",
      "schedule": "0 9 * * *"
    }
  ]
}
